# Butlers base image — system deps, LLM runtime CLIs, uv.
#
# This image changes infrequently (only when system deps or npm packages
# change). Build it once and reference from Dockerfile:
#
#   docker build -f Dockerfile.base -t butlers-base .
#
# The main Dockerfile uses this as its base, so app rebuilds only
# re-run Python dependency install and source copy (~30s vs ~5min).

FROM python:3.12-slim

# System dependencies (single layer, sorted for readability)
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    git \
    gnupg \
    && rm -rf /var/lib/apt/lists/*

# Node.js 22 (for LLM runtime CLIs)
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# LLM runtime CLIs — each butler can use any of these via butler.toml
RUN npm install -g \
    @anthropic-ai/claude-code \
    @google/gemini-cli \
    @openai/codex \
    opencode-ai

# uv package manager
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:${PATH}"

WORKDIR /app
