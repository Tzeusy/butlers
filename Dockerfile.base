# syntax=docker/dockerfile:1.7

# Butlers base image — system deps, LLM runtime CLIs, uv.
#
# This image changes infrequently (only when system deps or npm packages
# change). Build it once and reference from Dockerfile:
#
#   docker build -f Dockerfile.base -t butlers-base .
#
# The main Dockerfile uses this as its base, so app rebuilds only
# re-run Python dependency install and source copy (~30s vs ~5min).

FROM python:3.12-slim

# System dependencies (single layer, sorted for readability)
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    gh \
    git \
    gnupg \
    ripgrep \
    && rm -rf /var/lib/apt/lists/*

# Node.js 22 (for LLM runtime CLIs)
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# LLM runtime CLIs — pinned to exact versions for reproducibility.
# To update: bump versions here, verify with `npm view <pkg>@<ver>`, rebuild.
RUN --mount=type=cache,target=/root/.npm \
    npm install -g \
    @anthropic-ai/claude-code@2.1.179 \
    @google/gemini-cli@0.46.0 \
    @openai/codex@0.140.0 \
    opencode-ai@1.17.7

# Emit an auditable CLI version manifest — inspect with:
#   docker run --rm <image> cat /opt/cli-versions.txt
RUN mkdir -p /opt \
    && node --version > /opt/cli-versions.txt \
    && (npm list -g --depth=0 2>/dev/null || true) >> /opt/cli-versions.txt

# uv package manager. Install into /usr/local/bin and assert the binary exists so
# a transient installer/download problem cannot produce a broken base image.
RUN python -m pip install --no-cache-dir uv \
    && uv --version

WORKDIR /app
