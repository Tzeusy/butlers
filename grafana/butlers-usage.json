{
  "annotations": { "list": [{ "builtIn": 1, "datasource": { "type": "grafana", "uid": "-- Grafana --" }, "enable": true, "hide": true, "iconColor": "rgba(0, 211, 255, 1)", "name": "Annotations & Alerts", "type": "dashboard" }] },
  "description": "Per-butler session rates, LLM token consumption by model, buffer throughput, and scheduled task dispatch. All panels filter by butler.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "id": 100, "title": "Sessions", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "lineWidth": 1 }, "unit": "reqps" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 }, "id": 1,
      "options": { "legend": { "calcs": ["mean", "last"], "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by(butler) (rate(butlers_spawner_session_duration_ms_milliseconds_count{job=\"butlers\", butler=~\"$butler\"}[$__rate_interval]))", "legendFormat": "{{butler}}", "refId": "A" }],
      "title": "Session Rate (sessions/s) per Butler", "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 15, "lineWidth": 1, "stacking": { "group": "A", "mode": "normal" } }, "unit": "short" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 }, "id": 2,
      "options": { "legend": { "calcs": ["max", "last"], "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by(butler) (butlers_spawner_active_sessions{job=\"butlers\", butler=~\"$butler\"})", "legendFormat": "{{butler}}", "refId": "A" }],
      "title": "Active Sessions per Butler", "type": "timeseries"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }, "id": 101, "title": "Token Usage", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "lineWidth": 1 }, "unit": "short" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 }, "id": 3,
      "options": { "legend": { "calcs": ["mean", "last"], "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by(butler, model) (rate(butlers_spawner_input_tokens_total{job=\"butlers\", butler=~\"$butler\"}[$__rate_interval]))", "legendFormat": "{{butler}} / {{model}}", "refId": "A" }],
      "title": "Input Tokens Rate (tokens/s)", "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "lineWidth": 1 }, "unit": "short" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 }, "id": 4,
      "options": { "legend": { "calcs": ["mean", "last"], "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by(butler, model) (rate(butlers_spawner_output_tokens_total{job=\"butlers\", butler=~\"$butler\"}[$__rate_interval]))", "legendFormat": "{{butler}} / {{model}}", "refId": "A" }],
      "title": "Output Tokens Rate (tokens/s)", "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "mappings": [], "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } } },
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 18 }, "id": 5,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by(butler, model) (increase(butlers_spawner_input_tokens_total{job=\"butlers\", butler=~\"$butler\"}[$__range]))", "legendFormat": "{{butler}} / {{model}}", "refId": "A" }],
      "title": "Total Input Tokens (window)", "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "mappings": [], "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } } },
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 18 }, "id": 6,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by(butler, model) (increase(butlers_spawner_output_tokens_total{job=\"butlers\", butler=~\"$butler\"}[$__range]))", "legendFormat": "{{butler}} / {{model}}", "refId": "A" }],
      "title": "Total Output Tokens (window)", "type": "stat"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 }, "id": 102, "title": "Buffer Throughput", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 15, "lineWidth": 1, "stacking": { "group": "A", "mode": "normal" } }, "unit": "mps" } },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 23 }, "id": 7,
      "options": { "legend": { "calcs": ["mean", "last"], "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by(butler, path) (rate(butlers_buffer_enqueue_messages_total{job=\"butlers\", butler=~\"$butler\"}[$__rate_interval]))", "legendFormat": "{{butler}} ({{path}})", "refId": "A" }],
      "title": "Buffer Enqueue Rate (hot / cold)", "type": "timeseries"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 }, "id": 103, "title": "Scheduled Tasks", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 15, "lineWidth": 1, "stacking": { "group": "A", "mode": "normal" } }, "unit": "reqps" } },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 32 }, "id": 8,
      "options": { "legend": { "calcs": ["mean", "last"], "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by(butler, task_name, outcome) (rate(butlers_scheduler_tasks_dispatched_tasks_total{job=\"butlers\", butler=~\"$butler\"}[$__rate_interval]))", "legendFormat": "{{butler}} / {{task_name}} ({{outcome}})", "refId": "A" }],
      "title": "Scheduled Tasks Dispatched Rate", "type": "timeseries"
    }

  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["butlers", "opentelemetry", "ai-agents", "usage"],
  "templating": {
    "list": [
      {
        "current": {}, "hide": 0, "includeAll": false, "label": "Datasource", "name": "datasource",
        "options": [], "query": "prometheus", "refresh": 1, "type": "datasource"
      },
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
