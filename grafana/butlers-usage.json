        "options": [], "query": { "query": "label_values(butlers_buffer_process_latency_ms_milliseconds_count{job=\"butlers\"}, butler)", "refId": "StandardVariableQuery" },
        "refresh": 2, "sort": 1, "type": "query"
      }
    ]
  },
  "time": { "from": "now-3h", "to": "now" },
