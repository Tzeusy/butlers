      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.95, sum by(le) (rate(butlers_switchboard_end_to_end_latency_ms_milliseconds_bucket{job=\"butlers\"}[$__rate_interval])))", "legendFormat": "E2E P95", "refId": "A" }],
      "title": "E2E Latency P95", "type": "stat"
