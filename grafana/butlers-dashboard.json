      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(butlers_spawner_queued_triggers{job=\"butlers\"})", "legendFormat": "Queued", "refId": "A" }],
      "title": "Queued Triggers", "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
