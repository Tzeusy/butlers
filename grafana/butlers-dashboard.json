      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(butlers_spawner_active_sessions{job=\"butlers\"})", "legendFormat": "Active Sessions", "refId": "A" }],
      "title": "Active Sessions", "type": "stat"
