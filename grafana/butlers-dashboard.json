      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(rate(butlers_switchboard_message_received_total{job=\"butlers\"}[$__rate_interval]))", "legendFormat": "msg/s", "refId": "A" }],
      "title": "Message Throughput", "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" }, "mappings": [], "unit": "ms",
