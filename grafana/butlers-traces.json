        "options": [], "query": "{ resource.service.name=\"butlers\" } | select(butler.name)",
        "refresh": 2, "sort": 1, "type": "query"
      }
    ]
  },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
