{
  "annotations": { "list": [{ "builtIn": 1, "datasource": { "type": "grafana", "uid": "-- Grafana --" }, "enable": true, "hide": true, "iconColor": "rgba(0, 211, 255, 1)", "name": "Annotations & Alerts", "type": "dashboard" }] },
  "description": "Trace exploration via Tempo: search traces, inspect LLM session durations, span breakdowns, error rates, and switchboard message pipelines.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "id": 100, "title": "Trace Search", "type": "row" },

    {
      "datasource": { "type": "tempo", "uid": "tempo" },
      "fieldConfig": { "defaults": {} },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 1 }, "id": 1,
      "options": {},
      "targets": [{
        "datasource": { "type": "tempo", "uid": "tempo" },
        "queryType": "traceqlSearch",
        "filters": [
          { "id": "service-name", "tag": "resource.service.name", "operator": "=", "value": ["butlers"], "scope": "resource" },
          { "id": "butler-name", "tag": "butler.name", "operator": "=", "value": ["$butler_name"], "scope": "span", "valueType": "string" }
        ],
        "limit": 20,
        "refId": "A"
      }],
      "title": "Trace Search", "type": "traces"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }, "id": 101, "title": "LLM Sessions", "type": "row" },

    {
      "datasource": { "type": "tempo", "uid": "tempo" },
      "fieldConfig": { "defaults": {} },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 10 }, "id": 2,
      "options": {},
      "targets": [{
        "datasource": { "type": "tempo", "uid": "tempo" },
        "queryType": "traceqlSearch",
        "filters": [
          { "id": "service-name", "tag": "resource.service.name", "operator": "=", "value": ["butlers"], "scope": "resource" },
          { "id": "span-name", "tag": "name", "operator": "=", "value": ["butler.llm_session"], "scope": "span" }
        ],
        "limit": 20,
        "refId": "A"
      }],
      "title": "LLM Session Spans", "type": "traces"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 }, "id": 102, "title": "Span Rates & Errors", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 15, "lineWidth": 1, "stacking": { "group": "A", "mode": "normal" } }, "unit": "reqps" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 }, "id": 3,
      "options": { "legend": { "calcs": ["mean", "last"], "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "sum by(span_name) (rate(traces_spanmetrics_calls_total{service=\"butlers\"}[$__rate_interval]))",
        "legendFormat": "{{span_name}}", "refId": "A"
      }],
      "title": "Trace Count by Root Span Name", "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "lineWidth": 1 }, "unit": "reqps" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 }, "id": 4,
      "options": { "legend": { "calcs": ["mean", "last"], "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "expr": "sum by(span_name) (rate(traces_spanmetrics_calls_total{service=\"butlers\", status_code=\"STATUS_CODE_ERROR\"}[$__rate_interval]))",
        "legendFormat": "{{span_name}}", "refId": "A"
      }],
      "title": "Error Spans Rate", "type": "timeseries"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 }, "id": 103, "title": "Switchboard Pipeline", "type": "row" },

    {
      "datasource": { "type": "tempo", "uid": "tempo" },
      "fieldConfig": { "defaults": {} },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 }, "id": 5,
      "options": {},
      "targets": [{
        "datasource": { "type": "tempo", "uid": "tempo" },
        "queryType": "traceqlSearch",
        "filters": [
          { "id": "service-name", "tag": "resource.service.name", "operator": "=", "value": ["butlers"], "scope": "resource" },
          { "id": "span-name", "tag": "name", "operator": "=", "value": ["butlers.switchboard.message"], "scope": "span" }
        ],
        "limit": 20,
        "refId": "A"
      }],
      "title": "Switchboard Message Pipeline Traces", "type": "traces"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 }, "id": 104, "title": "Service Graph", "type": "row" },

    {
      "datasource": { "type": "tempo", "uid": "tempo" },
      "fieldConfig": { "defaults": {} },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 37 }, "id": 6,
      "options": {},
      "targets": [{
        "datasource": { "type": "tempo", "uid": "tempo" },
        "queryType": "serviceMap",
        "serviceMapQuery": "{resource.service.name=\"butlers\"}",
        "refId": "A"
      }],
      "title": "Service Graph", "type": "nodeGraph"
    }

  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["butlers", "opentelemetry", "ai-agents", "traces", "tempo"],
  "templating": {
    "list": [
      {
        "current": {}, "hide": 0, "includeAll": false, "label": "Datasource", "name": "datasource",
        "options": [], "query": "prometheus", "refresh": 1, "type": "datasource"
      },
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "tempo", "uid": "tempo" },
