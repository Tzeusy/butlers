    {
      "type": "text",
      "id": "schema_text",
      "x": 78,
      "y": 204,
      "width": 330,
      "height": 170,
      "text": "key         TEXT        PRIMARY KEY\nvalue       JSONB       NOT NULL\nversion     INTEGER     NOT NULL DEFAULT 1\nupdated_at  TIMESTAMPTZ NOT NULL",
      "originalText": "key         TEXT        PRIMARY KEY\nvalue       JSONB       NOT NULL\nversion     INTEGER     NOT NULL DEFAULT 1\nupdated_at  TIMESTAMPTZ NOT NULL",
      "fontSize": 13,
