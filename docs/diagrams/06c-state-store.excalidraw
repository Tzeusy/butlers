      "id": "schema_note",
      "x": 60,
      "y": 392,
      "width": 360,
      "height": 40,
      "text": "version: INTEGER starting at 1, increments on every write\n(used as CAS token for optimistic concurrency)",
      "originalText": "version: INTEGER starting at 1, increments on every write\n(used as CAS token for optimistic concurrency)",
