    {
      "type": "text",
      "id": "crud_text",
      "x": 496,
      "y": 162,
      "width": 452,
      "height": 268,
      "text": "state_get(pool, key)\n  \u2192 value | None\n\nstate_set(pool, key, value)\n  \u2192 new_version: int        [UPSERT]\n  INSERT ... ON CONFLICT DO UPDATE\n  version = version + 1\n\nstate_compare_and_set(pool, key,\n  expected_version, new_value)\n  \u2192 new_version: int\n  WHERE key=$1 AND version=$2\n  raises CASConflictError if mismatch\n\nstate_delete(pool, key) \u2192 None\n  [no-op if key missing]\n\nstate_list(pool, prefix?, keys_only=True)\n  \u2192 list[str] | list[{key, value}]",
      "originalText": "state_get(pool, key)\n  \u2192 value | None\n\nstate_set(pool, key, value)\n  \u2192 new_version: int        [UPSERT]\n  INSERT ... ON CONFLICT DO UPDATE\n  version = version + 1\n\nstate_compare_and_set(pool, key,\n  expected_version, new_value)\n  \u2192 new_version: int\n  WHERE key=$1 AND version=$2\n  raises CASConflictError if mismatch\n\nstate_delete(pool, key) \u2192 None\n  [no-op if key missing]\n\nstate_list(pool, prefix?, keys_only=True)\n  \u2192 list[str] | list[{key, value}]",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#4ade80",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 100023,
      "version": 2,
      "versionNonce": 100024,
      "isDeleted": false,
      "groupIds": [],
      "boundElements": null,
      "link": null,
      "locked": false,
      "containerId": null,
      "lineHeight": 1.55
    },
