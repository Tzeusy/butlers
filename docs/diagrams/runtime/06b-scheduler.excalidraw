    {
      "type": "text",
      "id": "toml_sync_detail_text",
      "x": 990,
      "y": 2185,
      "width": 260,
      "height": 240,
      "text": "TOML \u2194 DB Sync Rules\n(sync_schedules on startup)\n\nINSERT new tasks\n  source='toml', enabled=true\n  next_run_at = _next_run(cron)\n\nUPDATE if changed:\n  cron, prompt, job_name,\n  job_args, complexity, enabled\n  OR source!='toml'\n\nDISABLE removed tasks:\n  enabled=false\n  (DB-source tasks survive)\n\nTOML wins on name conflict\n  (reclaims DB-source tasks)",
      "originalText": "TOML \u2194 DB Sync Rules\n(sync_schedules on startup)\n\nINSERT new tasks\n  source='toml', enabled=true\n  next_run_at = _next_run(cron)\n\nUPDATE if changed:\n  cron, prompt, job_name,\n  job_args, complexity, enabled\n  OR source!='toml'\n\nDISABLE removed tasks:\n  enabled=false\n  (DB-source tasks survive)\n\nTOML wins on name conflict\n  (reclaims DB-source tasks)",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
