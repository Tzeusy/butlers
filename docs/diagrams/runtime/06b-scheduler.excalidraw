    {
      "type": "text",
      "id": "example_schedule_text",
      "x": 530,
      "y": 2185,
      "width": 380,
      "height": 240,
      "text": "Example: roster/general/butler.toml\n\n[[butler.schedule]]\nname = \"memory_consolidation\"\ncron = \"0 */6 * * *\"\ndispatch_mode = \"job\"\njob_name = \"memory_consolidation\"\n\n[[butler.schedule]]\nname = \"eod-tomorrow-prep\"\ncron = \"0 15 * * *\"\ndispatch_mode = \"prompt\"\nprompt = \"\"\"\n  End-of-day briefing: review tomorrow's\n  calendar and send a prep summary.\n  Call notify(channel='telegram', ...) \n\"\"\"",
      "originalText": "Example: roster/general/butler.toml\n\n[[butler.schedule]]\nname = \"memory_consolidation\"\ncron = \"0 */6 * * *\"\ndispatch_mode = \"job\"\njob_name = \"memory_consolidation\"\n\n[[butler.schedule]]\nname = \"eod-tomorrow-prep\"\ncron = \"0 15 * * *\"\ndispatch_mode = \"prompt\"\nprompt = \"\"\"\n  End-of-day briefing: review tomorrow's\n  calendar and send a prep summary.\n  Call notify(channel='telegram', ...) \n\"\"\"",
