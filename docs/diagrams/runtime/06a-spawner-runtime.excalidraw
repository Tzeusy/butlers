    {
      "type": "text",
      "id": "resolve_model_sql",
      "x": 420,
      "y": 1508,
      "width": 400,
      "height": 190,
      "text": "SQL: shared.model_catalog mc\n  LEFT JOIN shared.butler_model_overrides bmo\n    ON bmo.butler_name = $1\nWHERE\n  COALESCE(bmo.enabled, mc.enabled) = true\n  AND COALESCE(bmo.complexity_tier,\n               mc.complexity_tier) = $2\nORDER BY\n  COALESCE(bmo.priority, mc.priority) DESC,\n  mc.created_at ASC\nLIMIT 1\n→ (runtime_type, model_id, extra_args) | None",
      "originalText": "SQL: shared.model_catalog mc\n  LEFT JOIN shared.butler_model_overrides bmo\n    ON bmo.butler_name = $1\nWHERE\n  COALESCE(bmo.enabled, mc.enabled) = true\n  AND COALESCE(bmo.complexity_tier,\n               mc.complexity_tier) = $2\nORDER BY\n  COALESCE(bmo.priority, mc.priority) DESC,\n  mc.created_at ASC\nLIMIT 1\n→ (runtime_type, model_id, extra_args) | None",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#075985",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 103034,
      "version": 1,
      "versionNonce": 103035,
      "isDeleted": false,
      "groupIds": [],
      "boundElements": null,
      "link": null,
