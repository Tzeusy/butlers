    {
      "type": "text",
      "id": "resolution_fallback_text",
      "x": 900,
      "y": 1508,
      "width": 240,
      "height": 90,
      "text": "1. catalog hit → (runtime, model, extra_args)\n2. catalog miss → toml_fallback\n3. unregistered runtime → toml_fallback\n4. pool=None → toml_fallback\n\nresolution_source: \"catalog\" | \"toml_fallback\"",
      "originalText": "1. catalog hit → (runtime, model, extra_args)\n2. catalog miss → toml_fallback\n3. unregistered runtime → toml_fallback\n4. pool=None → toml_fallback\n\nresolution_source: \"catalog\" | \"toml_fallback\"",
