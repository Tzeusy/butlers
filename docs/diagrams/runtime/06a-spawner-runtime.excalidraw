    {
      "type": "text",
      "id": "drain_text",
      "x": 680,
      "y": 3028,
      "width": 340,
      "height": 110,
      "text": "stop_accepting():\n  _accepting = False\n  → no new trigger() calls accepted\n\ndrain(timeout=30.0):\n  wait for _in_flight_event (all tasks done)\n  on timeout → cancel remaining tasks\n  _in_flight_event.set()",
      "originalText": "stop_accepting():\n  _accepting = False\n  → no new trigger() calls accepted\n\ndrain(timeout=30.0):\n  wait for _in_flight_event (all tasks done)\n  on timeout → cancel remaining tasks\n  _in_flight_event.set()",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#78350f",
      "backgroundColor": "transparent",
