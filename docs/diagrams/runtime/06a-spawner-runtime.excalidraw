    {
      "type": "text",
      "id": "abc_methods",
      "x": 80,
      "y": 1838,
      "width": 340,
      "height": 230,
      "text": "@abstractmethod\n  binary_name → str\n\n@abstractmethod\n  invoke(prompt, system_prompt, mcp_servers,\n         env, max_turns, model, runtime_args,\n         cwd, timeout)\n  → (str|None, list[dict], dict|None)\n\n@abstractmethod\n  build_config_file(mcp_servers, tmp_dir) → Path\n\n@abstractmethod\n  parse_system_prompt_file(config_dir) → str\n\n  last_process_info → dict|None  (property)\n  create_worker() → RuntimeAdapter\n  reset() → None",
      "originalText": "@abstractmethod\n  binary_name → str\n\n@abstractmethod\n  invoke(prompt, system_prompt, mcp_servers,\n         env, max_turns, model, runtime_args,\n         cwd, timeout)\n  → (str|None, list[dict], dict|None)\n\n@abstractmethod\n  build_config_file(mcp_servers, tmp_dir) → Path\n\n@abstractmethod\n  parse_system_prompt_file(config_dir) → str\n\n  last_process_info → dict|None  (property)\n  create_worker() → RuntimeAdapter\n  reset() → None",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#4c1d95",
      "backgroundColor": "transparent",
