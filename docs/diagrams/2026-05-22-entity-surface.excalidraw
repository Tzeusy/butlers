    {
      "type": "text",
      "id": "route_hop_content",
      "x": 430,
      "y": 222,
      "width": 300,
      "height": 180,
      "text": "Component: HopPage\nArchetype: <Page archetype=\"overview\">\n\nQuery: ?center=<entity_id>\n  (defaults to owner entity)\n\nEndpoints:\n  GET /api/relationship/entities/{id}\n  GET /api/relationship/entities/{id}/neighbours\n\nFact contributors:\n  relationship: knows, family-of,\n  partner-of, co-attended,\n  colleague-of (relational predicates)",
      "originalText": "Component: HopPage\nArchetype: <Page archetype=\"overview\">\n\nQuery: ?center=<entity_id>\n  (defaults to owner entity)\n\nEndpoints:\n  GET /api/relationship/entities/{id}\n  GET /api/relationship/entities/{id}/neighbours\n\nFact contributors:\n  relationship: knows, family-of,\n  partner-of, co-attended,\n  colleague-of (relational predicates)",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
