    {
      "type": "text",
      "id": "module_chronicler_content",
      "x": 350,
      "y": 1238,
      "width": 240,
      "height": 166,
      "text": "Passive interaction sync\n(passive-interaction-sync spec)\n\nIngests from:\n  Telegram, email threads,\n  Discord channels\n\nWrites interaction facts:\n  interaction_message\n  interaction_meeting (via\n  Google Calendar events)\n\nEnriches with metadata:\n  direction, group_size\n\nSurfaces via:\n  /entities/{id}/interactions\n  /entities/{id}/activity",
      "originalText": "Passive interaction sync\n(passive-interaction-sync spec)\n\nIngests from:\n  Telegram, email threads,\n  Discord channels\n\nWrites interaction facts:\n  interaction_message\n  interaction_meeting (via\n  Google Calendar events)\n\nEnriches with metadata:\n  direction, group_size\n\nSurfaces via:\n  /entities/{id}/interactions\n  /entities/{id}/activity",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#374151",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
