    {
      "type": "text",
      "id": "module_relationship_content",
      "x": 70,
      "y": 1238,
      "width": 240,
      "height": 166,
      "text": "Writes via:\n  relationship_assert_fact()\n\nContact predicates:\n  has-email, has-phone,\n  has-handle, has-address,\n  has-birthday, has-website\n\nRelational predicates:\n  knows, family-of, partner-of,\n  colleague-of, co-attended\n\nOther:\n  dunbar_tier_override\n  contact_note, gift, loan\n  interaction_*, life_event",
      "originalText": "Writes via:\n  relationship_assert_fact()\n\nContact predicates:\n  has-email, has-phone,\n  has-handle, has-address,\n  has-birthday, has-website\n\nRelational predicates:\n  knows, family-of, partner-of,\n  colleague-of, co-attended\n\nOther:\n  dunbar_tier_override\n  contact_note, gift, loan\n  interaction_*, life_event",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
