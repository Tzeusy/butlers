    {
      "type": "text",
      "id": "route_concentration_content",
      "x": 70,
      "y": 532,
      "width": 320,
      "height": 180,
      "text": "Component: ConcentrationPage\nArchetype: <Page archetype=\"overview\">\n\nQuery: ?pred=<predicate>\n  Default: knows\n\nEndpoints:\n  GET /api/relationship/entities/concentration\n    ?pred=<predicate>\n\nPredicate tabs enumerated from:\n  entity_predicate_registry\n  (NOT hardcoded to 4 predicates)\n\nHeader rollup: total + top3Share\n  font-variant-numeric: tabular-nums",
      "originalText": "Component: ConcentrationPage\nArchetype: <Page archetype=\"overview\">\n\nQuery: ?pred=<predicate>\n  Default: knows\n\nEndpoints:\n  GET /api/relationship/entities/concentration\n    ?pred=<predicate>\n\nPredicate tabs enumerated from:\n  entity_predicate_registry\n  (NOT hardcoded to 4 predicates)\n\nHeader rollup: total + top3Share\n  font-variant-numeric: tabular-nums",
