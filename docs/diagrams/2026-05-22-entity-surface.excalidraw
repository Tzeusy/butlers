    {
      "type": "text",
      "id": "module_calendar_content",
      "x": 630,
      "y": 1238,
      "width": 240,
      "height": 166,
      "text": "Google Calendar integration\n(module-calendar spec)\n\nSyncs meeting events\n  → interaction_meeting facts\n\nEnriches interactions with:\n  event title (summary)\n  start/end times (valid_at)\n  attendees (entity links)\n\nSurfaces via:\n  /entities/{id}/interactions\n  (predicate LIKE interaction_%)\n  /entities/{id}/timeline",
      "originalText": "Google Calendar integration\n(module-calendar spec)\n\nSyncs meeting events\n  → interaction_meeting facts\n\nEnriches interactions with:\n  event title (summary)\n  start/end times (valid_at)\n  attendees (entity links)\n\nSurfaces via:\n  /entities/{id}/interactions\n  (predicate LIKE interaction_%)\n  /entities/{id}/timeline",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#374151",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
