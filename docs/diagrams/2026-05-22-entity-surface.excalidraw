    {
      "type": "text",
      "id": "module_memory_content",
      "x": 910,
      "y": 1238,
      "width": 240,
      "height": 166,
      "text": "Entity identity layer\n(memory.facts, public.entities)\n\nOwns: public.entities table\n  entity_type, canonical_name,\n  aliases, roles, metadata\n\nBidirectional bridge:\n  /entities/:id (memory view)\n  → /butlers/relationship/\n    entities/:id (relationship view)\n  \"View relationship activity →\"\n  link (person entities only)\n\nNot a fact contributor to\n  relationship.entity_facts directly",
      "originalText": "Entity identity layer\n(memory.facts, public.entities)\n\nOwns: public.entities table\n  entity_type, canonical_name,\n  aliases, roles, metadata\n\nBidirectional bridge:\n  /entities/:id (memory view)\n  → /butlers/relationship/\n    entities/:id (relationship view)\n  \"View relationship activity →\"\n  link (person entities only)\n\nNot a fact contributor to\n  relationship.entity_facts directly",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
