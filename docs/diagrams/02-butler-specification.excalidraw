    {
      "type": "text",
      "id": "module_interface_text",
      "x": 80, "y": 995,
      "width": 480, "height": 105,
      "text": "register_tools(mcp, config, db)  — add MCP tools to FastMCP server\nmigration_revisions()           — Alembic branch label for module migrations\non_startup(config, db, credential_store)  — async init after dependency resolution\non_shutdown()                   — async cleanup during butler shutdown\ntool_metadata()                 — sensitivity metadata (ToolMeta) per tool name",
      "originalText": "register_tools(mcp, config, db)  — add MCP tools to FastMCP server\nmigration_revisions()           — Alembic branch label for module migrations\non_startup(config, db, credential_store)  — async init after dependency resolution\non_shutdown()                   — async cleanup during butler shutdown\ntool_metadata()                 — sensitivity metadata (ToolMeta) per tool name",
      "fontSize": 12, "fontFamily": 3,
      "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#374151", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid",
      "roughness": 0, "opacity": 100, "angle": 0,
