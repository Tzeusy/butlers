      "y": 497,
      "width": 250,
      "height": 20,
      "text": "Module Dependency Resolution",
      "originalText": "Module Dependency Resolution",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#14532d",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
