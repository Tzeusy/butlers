    {
      "type": "rectangle",
      "id": "policy_layer3",
      "x": 970,
      "y": 2393,
      "width": 440,
      "height": 350,
      "strokeColor": "#15803d",
      "backgroundColor": "#f0fdf4",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 203001,
      "version": 1,
      "versionNonce": 203002,
