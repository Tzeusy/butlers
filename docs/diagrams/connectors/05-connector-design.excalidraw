    {
      "type": "text",
      "id": "secJ_subtitle",
      "x": 60,
      "y": 2351,
      "width": 1000,
      "height": 18,
      "text": "Applied in order: Layer 1 (label filter) gates ingestion before tier assignment. Layers 2 and 3 run only if label check passes.",
      "originalText": "Applied in order: Layer 1 (label filter) gates ingestion before tier assignment. Layers 2 and 3 run only if label check passes.",
