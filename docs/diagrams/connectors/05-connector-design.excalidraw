    {
      "type": "rectangle",
      "id": "policy_layer1",
      "x": 80,
      "y": 2393,
      "width": 390,
      "height": 350,
      "strokeColor": "#c2410c",
      "backgroundColor": "#fff7ed",
      "fillStyle": "solid",
