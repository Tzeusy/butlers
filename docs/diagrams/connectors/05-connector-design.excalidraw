    {
      "type": "text",
      "id": "infra_postgres_txt",
      "x": 86,
      "y": 1991,
      "width": 238,
      "height": 258,
      "text": "PostgreSQL\n\nswitchboard.connector_registry\n  checkpoint_cursor\n  last_heartbeat_at\n  connector_type\n  endpoint_identity\n\ncursor_store.py API:\n  save_cursor(pool, type, id, val)\n  load_cursor(pool, type, id)\n\nPool: asyncpg\nmin_size=1, max_size=2\ncommand_timeout=5s",
      "originalText": "PostgreSQL\n\nswitchboard.connector_registry\n  checkpoint_cursor\n  last_heartbeat_at\n  connector_type\n  endpoint_identity\n\ncursor_store.py API:\n  save_cursor(pool, type, id, val)\n  load_cursor(pool, type, id)\n\nPool: asyncpg\nmin_size=1, max_size=2\ncommand_timeout=5s",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
