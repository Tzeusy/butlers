    {
      "type": "text",
      "id": "scheduled_detail",
      "x": 952, "y": 452,
      "width": 366, "height": 186,
      "text": "connector-stats-hourly-rollup\n  cron: \"5 * * * *\"  (5 min past each hour)\n\nconnector-stats-daily-rollup\n  cron: \"15 0 * * *\"  (00:15 daily)\n\nconnector-stats-pruning\n  cron: \"30 1 * * *\"  (01:30 daily)\n\nmemory-consolidation\n  cron: \"0 */6 * * *\"  (every 6 hours)\n\nmemory-episode-cleanup\n  cron: \"0 4 * * *\"  (04:00 daily)\n\neligibility-sweep\n  cron: \"*/5 * * * *\"  (every 5 minutes)",
      "originalText": "connector-stats-hourly-rollup\n  cron: \"5 * * * *\"  (5 min past each hour)\n\nconnector-stats-daily-rollup\n  cron: \"15 0 * * *\"  (00:15 daily)\n\nconnector-stats-pruning\n  cron: \"30 1 * * *\"  (01:30 daily)\n\nmemory-consolidation\n  cron: \"0 */6 * * *\"  (every 6 hours)\n\nmemory-episode-cleanup\n  cron: \"0 4 * * *\"  (04:00 daily)\n\neligibility-sweep\n  cron: \"*/5 * * * *\"  (every 5 minutes)",
