    {
      "type": "text",
      "id": "db_detail",
      "x": 70, "y": 844,
      "width": 400, "height": 208,
      "text": "shared.ingestion_events\n  id UUID7 PK (= request_id)\n  source_channel, source_provider\n  dedupe_key, triage_decision, triage_target\n\nmessage_inbox  (month-partitioned)\n  request_context JSONB  (request_id, source_channel\n    source_sender_identity, source_thread_identity)\n  raw_payload JSONB, normalized_text TEXT\n  lifecycle_state, received_at TIMESTAMPTZ\n\nroute_inbox\n  id UUID,  route_envelope JSONB\n  lifecycle_state: accepted | processing\n                  | processed | errored\n\npipeline_classification_log\n  request_id, target_butler, latency_ms\n  source_channel, classification_error",
      "originalText": "shared.ingestion_events\n  id UUID7 PK (= request_id)\n  source_channel, source_provider\n  dedupe_key, triage_decision, triage_target\n\nmessage_inbox  (month-partitioned)\n  request_context JSONB  (request_id, source_channel\n    source_sender_identity, source_thread_identity)\n  raw_payload JSONB, normalized_text TEXT\n  lifecycle_state, received_at TIMESTAMPTZ\n\nroute_inbox\n  id UUID,  route_envelope JSONB\n  lifecycle_state: accepted | processing\n                  | processed | errored\n\npipeline_classification_log\n  request_id, target_butler, latency_ms\n  source_channel, classification_error",
