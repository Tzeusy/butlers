    {
      "type": "text",
      "id": "buf_cold_detail",
      "x": 690, "y": 476,
      "width": 209, "height": 86,
      "text": "DB scanner polls every 30s\ngrace period: 10s\nbatch size: 50 rows\n\nPicks up message_inbox rows\nwith lifecycle_state='accepted'\nthat are older than grace_s\n→ re-enqueues to tier queue",
      "originalText": "DB scanner polls every 30s\ngrace period: 10s\nbatch size: 50 rows\n\nPicks up message_inbox rows\nwith lifecycle_state='accepted'\nthat are older than grace_s\n→ re-enqueues to tier queue",
      "fontSize": 10,
      "fontFamily": 3,
      "textAlign": "left",
