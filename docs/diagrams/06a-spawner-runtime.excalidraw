    {
      "type": "text",
      "id": "tcc_box_txt",
      "x": 1170,
      "y": 944,
      "width": 320,
      "height": 140,
      "text": "tool_call_capture.py\n\ncapture_tool_call(tool_name, input, result)\n  — called from MCP tool handlers\n  — keyed by runtime_session_id (ContextVar)\n\nensure_runtime_session_capture(session_id)\nconsume_runtime_session_tool_calls(id)\n  — returns & clears buffer post-session\n\nMerged with parser tool calls via\n_merge_tool_call_records()",
      "originalText": "tool_call_capture.py\n\ncapture_tool_call(tool_name, input, result)\n  — called from MCP tool handlers\n  — keyed by runtime_session_id (ContextVar)\n\nensure_runtime_session_capture(session_id)\nconsume_runtime_session_tool_calls(id)\n  — returns & clears buffer post-session\n\nMerged with parser tool calls via\n_merge_tool_call_records()",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "middle",
      "strokeColor": "#374151",
      "backgroundColor": "transparent",
