    },
    {
      "type": "text",
      "id": "approval_detail_body",
      "x": 80,
      "y": 774,
      "width": 440,
      "height": 256,
      "text": "Flow:\n  1. Butler detects sensitive command\n  2. Creates pending approval record\n  3. Notifies owner via Telegram\n  4. Owner reacts: \u2705 approve | \u274c deny\n  5. On approve \u2192 ha_call_service() executes\n  6. On deny \u2192 action skipped, preference noted\n  7. memory_store_fact: outcome logged\n\nSensitivity Levels:\n  HIGH (require explicit approval):\n    \u2022 Door locks / security system arm/disarm\n    \u2022 HVAC setpoints (major change >5\u00b0F)\n    \u2022 Disabling automations\n  MEDIUM (standing rules may auto-approve):\n    \u2022 Routine light/device toggles\n    \u2022 Scene activations (pre-approved scenes)\n    \u2022 Minor thermostat adjustments (\u22642\u00b0F)\n  AUTO-APPROVED:\n    \u2022 Read-only queries (sensor readings)\n    \u2022 Memory lookups and logging\n    \u2022 Scheduled notification tasks",
      "originalText": "Flow:\n  1. Butler detects sensitive command\n  2. Creates pending approval record\n  3. Notifies owner via Telegram\n  4. Owner reacts: \u2705 approve | \u274c deny\n  5. On approve \u2192 ha_call_service() executes\n  6. On deny \u2192 action skipped, preference noted\n  7. memory_store_fact: outcome logged\n\nSensitivity Levels:\n  HIGH (require explicit approval):\n    \u2022 Door locks / security system arm/disarm\n    \u2022 HVAC setpoints (major change >5\u00b0F)\n    \u2022 Disabling automations\n  MEDIUM (standing rules may auto-approve):\n    \u2022 Routine light/device toggles\n    \u2022 Scene activations (pre-approved scenes)\n    \u2022 Minor thermostat adjustments (\u22642\u00b0F)\n  AUTO-APPROVED:\n    \u2022 Read-only queries (sensor readings)\n    \u2022 Memory lookups and logging\n    \u2022 Scheduled notification tasks",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#374151",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 400009,
      "version": 1,
      "versionNonce": 400010,
      "isDeleted": false,
      "groupIds": [],
      "boundElements": null,
      "link": null,
      "locked": false,
      "containerId": null,
      "lineHeight": 1.35
    },
