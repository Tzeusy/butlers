      "x": 2240,
      "y": 1555,
      "width": 540,
      "height": 810,
      "text": "All tables schema-qualified as education.*\n\neducation.mind_maps\n──────────────\nid UUID PK\ntitle TEXT\nroot_node_id UUID FK → mind_map_nodes\nstatus TEXT  (active/completed/abandoned)\nmetadata JSONB\n\neducation.mind_map_nodes\n──────────────\nid UUID PK\nmind_map_id UUID FK → mind_maps\nlabel TEXT, description TEXT\ndepth INTEGER\nmastery_score FLOAT\nmastery_status TEXT  (unseen/diagnosed/\n  learning/reviewing/mastered)\nease_factor FLOAT, repetitions INTEGER\nnext_review_at, last_reviewed_at\nsequence INTEGER\n\neducation.mind_map_edges\n──────────────\nparent_node_id UUID FK → mind_map_nodes\nchild_node_id UUID FK → mind_map_nodes\nedge_type TEXT  (prerequisite/related)\nPK (parent_node_id, child_node_id)\n\neducation.quiz_responses\n──────────────\nid UUID PK\nnode_id UUID FK → mind_map_nodes\nmind_map_id UUID FK → mind_maps\nquestion_text TEXT\nuser_answer TEXT\nquality INTEGER 0–5\nresponse_type TEXT  (diagnostic/teach/review)\nsession_id UUID\nresponded_at TIMESTAMPTZ\n\neducation.analytics_snapshots\n──────────────\nid UUID PK\nmind_map_id UUID FK → mind_maps\nsnapshot_date DATE\nmetrics JSONB\ncreated_at TIMESTAMPTZ\nUNIQUE (mind_map_id, snapshot_date)",
      "originalText": "All tables schema-qualified as education.*\n\neducation.mind_maps\n──────────────\nid UUID PK\ntitle TEXT\nroot_node_id UUID FK → mind_map_nodes\nstatus TEXT  (active/completed/abandoned)\nmetadata JSONB\n\neducation.mind_map_nodes\n──────────────\nid UUID PK\nmind_map_id UUID FK → mind_maps\nlabel TEXT, description TEXT\ndepth INTEGER\nmastery_score FLOAT\nmastery_status TEXT  (unseen/diagnosed/\n  learning/reviewing/mastered)\nease_factor FLOAT, repetitions INTEGER\nnext_review_at, last_reviewed_at\nsequence INTEGER\n\neducation.mind_map_edges\n──────────────\nparent_node_id UUID FK → mind_map_nodes\nchild_node_id UUID FK → mind_map_nodes\nedge_type TEXT  (prerequisite/related)\nPK (parent_node_id, child_node_id)\n\neducation.quiz_responses\n──────────────\nid UUID PK\nnode_id UUID FK → mind_map_nodes\nmind_map_id UUID FK → mind_maps\nquestion_text TEXT\nuser_answer TEXT\nquality INTEGER 0–5\nresponse_type TEXT  (diagnostic/teach/review)\nsession_id UUID\nresponded_at TIMESTAMPTZ\n\neducation.analytics_snapshots\n──────────────\nid UUID PK\nmind_map_id UUID FK → mind_maps\nsnapshot_date DATE\nmetrics JSONB\ncreated_at TIMESTAMPTZ\nUNIQUE (mind_map_id, snapshot_date)",
