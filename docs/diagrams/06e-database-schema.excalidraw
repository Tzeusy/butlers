    {
      "type": "text",
      "id": "contacts_module_text",
      "x": 720,
      "y": 2720,
      "width": 560,
      "height": 270,
      "text": "Contacts Module\n─────────────────────────\ncontacts_source_accounts\n  provider TEXT, account_id TEXT PK\n  subject_email TEXT\n  connected_at, last_success_at\n\ncontacts_sync_state\n  provider TEXT, account_id TEXT PK\n  sync_cursor TEXT\n  cursor_issued_at TIMESTAMPTZ\n  last_full_sync_at\n  last_incremental_sync_at\n  contact_versions JSONB\n  last_error TEXT\n\ncontacts_source_links\n  provider TEXT, account_id TEXT,\n  external_contact_id TEXT  PK\n  local_contact_id UUID\n  source_etag TEXT\n  first_seen_at, last_seen_at TIMESTAMPTZ\n  deleted_at TIMESTAMPTZ\n\nNote: shared.contact_info gets write\n  grants when contacts module enabled",
      "originalText": "Contacts Module\n─────────────────────────\ncontacts_source_accounts\n  provider TEXT, account_id TEXT PK\n  subject_email TEXT\n  connected_at, last_success_at\n\ncontacts_sync_state\n  provider TEXT, account_id TEXT PK\n  sync_cursor TEXT\n  cursor_issued_at TIMESTAMPTZ\n  last_full_sync_at\n  last_incremental_sync_at\n  contact_versions JSONB\n  last_error TEXT\n\ncontacts_source_links\n  provider TEXT, account_id TEXT,\n  external_contact_id TEXT  PK\n  local_contact_id UUID\n  source_etag TEXT\n  first_seen_at, last_seen_at TIMESTAMPTZ\n  deleted_at TIMESTAMPTZ\n\nNote: shared.contact_info gets write\n  grants when contacts module enabled",
