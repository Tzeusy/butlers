      "text": "butler_registry\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nname TEXT PK\nendpoint_url TEXT\ndescription TEXT\nmodules JSONB\nlast_seen_at, registered_at\n\nrouting_log\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nid UUID PK\nsource_butler TEXT\ntarget_butler TEXT\ntool_name TEXT\nsuccess BOOL\nduration_ms INTEGER\nerror TEXT, created_at\n\nmessage_inbox  (partitioned by month)\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nid UUID, received_at TIMESTAMPTZ PK\nrequest_context JSONB\nraw_payload JSONB\nnormalized_text TEXT\ndecomposition_output JSONB\ndispatch_outcomes JSONB\nresponse_summary TEXT\nlifecycle_state TEXT\nschema_version TEXT\nprocessing_metadata JSONB\ntrace_id TEXT, session_id UUID\n\ndashboard_audit_log\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nid UUID PK\nbutler TEXT\noperation TEXT\nrequest_summary JSONB\nresult TEXT\nerror TEXT\nuser_context JSONB\ncreated_at TIMESTAMPTZ\n\n+ 15 more tables: triage_rules, backfill_jobs,\n  routing_instructions, thread_affinity,\n  dead_letter_queue, operator_audit_log,\n  fanout_execution_log, connector_heartbeat,\n  connector_registry w/ capabilities/contracts,\n  notifications, ingress_dedupe, attachments...",
