    {
      "type": "text",
      "id": "relationship_tables_text",
      "x": 1520,
      "y": 680,
      "width": 640,
      "height": 950,
      "text": "contacts → moved to shared.contacts (core_007)\n\nrelationships\n──────────────\nid UUID PK\ncontact_a UUID FK → shared.contacts\ncontact_b UUID FK → shared.contacts\ntype TEXT, notes TEXT\n\nimportant_dates\n──────────────\nid UUID PK\ncontact_id UUID FK → shared.contacts\nlabel TEXT\nmonth INT, day INT, year INT\n\ninteractions\n──────────────\nid UUID PK\ncontact_id UUID FK → shared.contacts\ntype TEXT, summary TEXT\noccurred_at TIMESTAMPTZ\n\nnotes\n──────────────\nid UUID PK\ncontact_id UUID FK → shared.contacts\ncontent TEXT, emotion TEXT\n\nreminders\n──────────────\nid UUID PK\ncontact_id UUID FK → shared.contacts\nmessage TEXT\nreminder_type TEXT, cron TEXT, due_at\n\ngifts, loans, groups, group_members\nlabels, contact_labels, quick_facts\nactivity_feed, addresses, life_events\ntasks (contact tasks)\n\n── relationship_scores (rel_006) ──\nrelationship_scores\n──────────────\ncontact_id UUID FK → shared.contacts\noverall_score FLOAT\ncomponent_scores JSONB\ncalculated_at TIMESTAMPTZ\n\n── Memory module (opt-in) ──\nepisodes, facts, rules\nmemory_links, memory_events\nentities  (memory module)\n\n── Contacts module (opt-in) ──\ncontacts_source_accounts\ncontacts_sync_state\ncontacts_source_links\n\n── Approvals module (opt-in) ──\napproval_rules\npending_actions\napproval_events",
      "originalText": "contacts → moved to shared.contacts (core_007)\n\nrelationships\n──────────────\nid UUID PK\ncontact_a UUID FK → shared.contacts\ncontact_b UUID FK → shared.contacts\ntype TEXT, notes TEXT\n\nimportant_dates\n──────────────\nid UUID PK\ncontact_id UUID FK → shared.contacts\nlabel TEXT\nmonth INT, day INT, year INT\n\ninteractions\n──────────────\nid UUID PK\ncontact_id UUID FK → shared.contacts\ntype TEXT, summary TEXT\noccurred_at TIMESTAMPTZ\n\nnotes\n──────────────\nid UUID PK\ncontact_id UUID FK → shared.contacts\ncontent TEXT, emotion TEXT\n\nreminders\n──────────────\nid UUID PK\ncontact_id UUID FK → shared.contacts\nmessage TEXT\nreminder_type TEXT, cron TEXT, due_at\n\ngifts, loans, groups, group_members\nlabels, contact_labels, quick_facts\nactivity_feed, addresses, life_events\ntasks (contact tasks)\n\n── relationship_scores (rel_006) ──\nrelationship_scores\n──────────────\ncontact_id UUID FK → shared.contacts\noverall_score FLOAT\ncomponent_scores JSONB\ncalculated_at TIMESTAMPTZ\n\n── Memory module (opt-in) ──\nepisodes, facts, rules\nmemory_links, memory_events\nentities  (memory module)\n\n── Contacts module (opt-in) ──\ncontacts_source_accounts\ncontacts_sync_state\ncontacts_source_links\n\n── Approvals module (opt-in) ──\napproval_rules\npending_actions\napproval_events",
