    {
      "type": "text",
      "id": "connectors_filtered_events_text",
      "x": 80,
      "y": 3995,
      "width": 900,
      "height": 230,
      "text": "connectors.filtered_events  (core_027, partitioned by RANGE (received_at), monthly)\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nid UUID NOT NULL DEFAULT gen_random_uuid()\nreceived_at TIMESTAMPTZ NOT NULL  (partition key)\nconnector_type TEXT NOT NULL\nendpoint_identity TEXT NOT NULL\nexternal_message_id TEXT NOT NULL\nsource_channel TEXT NOT NULL\nsender_identity TEXT NOT NULL\nsubject_or_preview TEXT\nfilter_reason TEXT NOT NULL\nstatus TEXT NOT NULL DEFAULT 'filtered'\n  (filtered/error/replay_pending/replay_complete/replay_failed)\nfull_payload JSONB NOT NULL\nerror_detail TEXT\nreplay_requested_at, replay_completed_at TIMESTAMPTZ\ncreated_at TIMESTAMPTZ NOT NULL\nPRIMARY KEY (received_at, id)\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nINDEX: (connector_type, endpoint_identity, status, received_at DESC)  -- drain queries\nINDEX: (received_at DESC)  -- timeline queries\nFUNCTION: connectors_filtered_events_ensure_partition(ts)  -- idempotent partition mgmt",
      "originalText": "connectors.filtered_events  (core_027, partitioned by RANGE (received_at), monthly)\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nid UUID NOT NULL DEFAULT gen_random_uuid()\nreceived_at TIMESTAMPTZ NOT NULL  (partition key)\nconnector_type TEXT NOT NULL\nendpoint_identity TEXT NOT NULL\nexternal_message_id TEXT NOT NULL\nsource_channel TEXT NOT NULL\nsender_identity TEXT NOT NULL\nsubject_or_preview TEXT\nfilter_reason TEXT NOT NULL\nstatus TEXT NOT NULL DEFAULT 'filtered'\n  (filtered/error/replay_pending/replay_complete/replay_failed)\nfull_payload JSONB NOT NULL\nerror_detail TEXT\nreplay_requested_at, replay_completed_at TIMESTAMPTZ\ncreated_at TIMESTAMPTZ NOT NULL\nPRIMARY KEY (received_at, id)\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nINDEX: (connector_type, endpoint_identity, status, received_at DESC)  -- drain queries\nINDEX: (received_at DESC)  -- timeline queries\nFUNCTION: connectors_filtered_events_ensure_partition(ts)  -- idempotent partition mgmt",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#0f766e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 2000025,
      "version": 1,
      "versionNonce": 2000026,
      "isDeleted": false,
      "groupIds": [],
