    {
      "type": "text",
      "id": "travel_tables_text",
      "x": 1520,
      "y": 1755,
      "width": 640,
      "height": 610,
      "text": "All tables are schema-qualified as travel.*\n\ntravel.trips\n──────────────\nid UUID PK\nname TEXT, destination TEXT\nstart_date DATE, end_date DATE\nstatus TEXT  (planned/active/completed/cancelled)\nmetadata JSONB\n\ntravel.legs  (flights/trains/buses)\n──────────────\nid UUID PK\ntrip_id UUID FK → trips\ntype TEXT  (flight/train/bus/ferry)\ncarrier TEXT\ndeparture_airport_station TEXT\ndeparture_city TEXT, departure_at TIMESTAMPTZ\narrival_airport_station TEXT\narrival_city TEXT, arrival_at TIMESTAMPTZ\nconfirmation_number TEXT, pnr TEXT\nseat TEXT\n\ntravel.accommodations\n──────────────\nid UUID PK\ntrip_id UUID FK → trips\ntype TEXT  (hotel/airbnb/hostel)\nname TEXT, address TEXT\ncheck_in, check_out TIMESTAMPTZ\nconfirmation_number TEXT\n\ntravel.reservations\n──────────────\nid UUID PK\ntrip_id UUID FK → trips\ntype TEXT  (car_rental/restaurant/activity/tour)\nprovider TEXT, datetime TIMESTAMPTZ\nconfirmation_number TEXT\n\ntravel.documents\n──────────────\nid UUID PK\ntrip_id UUID FK → trips\ntype TEXT  (boarding_pass/visa/insurance/receipt)\nblob_ref TEXT, expiry_date DATE",
      "originalText": "All tables are schema-qualified as travel.*\n\ntravel.trips\n──────────────\nid UUID PK\nname TEXT, destination TEXT\nstart_date DATE, end_date DATE\nstatus TEXT  (planned/active/completed/cancelled)\nmetadata JSONB\n\ntravel.legs  (flights/trains/buses)\n──────────────\nid UUID PK\ntrip_id UUID FK → trips\ntype TEXT  (flight/train/bus/ferry)\ncarrier TEXT\ndeparture_airport_station TEXT\ndeparture_city TEXT, departure_at TIMESTAMPTZ\narrival_airport_station TEXT\narrival_city TEXT, arrival_at TIMESTAMPTZ\nconfirmation_number TEXT, pnr TEXT\nseat TEXT\n\ntravel.accommodations\n──────────────\nid UUID PK\ntrip_id UUID FK → trips\ntype TEXT  (hotel/airbnb/hostel)\nname TEXT, address TEXT\ncheck_in, check_out TIMESTAMPTZ\nconfirmation_number TEXT\n\ntravel.reservations\n──────────────\nid UUID PK\ntrip_id UUID FK → trips\ntype TEXT  (car_rental/restaurant/activity/tour)\nprovider TEXT, datetime TIMESTAMPTZ\nconfirmation_number TEXT\n\ntravel.documents\n──────────────\nid UUID PK\ntrip_id UUID FK → trips\ntype TEXT  (boarding_pass/visa/insurance/receipt)\nblob_ref TEXT, expiry_date DATE",
