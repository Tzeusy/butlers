    {
      "type": "text",
      "id": "shared_contacts_text",
      "x": 92,
      "y": 180,
      "width": 560,
      "height": 145,
      "text": "shared.contacts\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nid UUID PK\nname TEXT\nroles TEXT[] DEFAULT '{}'\n  (e.g. ['owner'])\nentity_id UUID \u2192 memory entity graph\ncreated_at, updated_at TIMESTAMPTZ\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nUNIQUE INDEX: owner singleton\n  WHERE 'owner' = ANY(roles)",
      "originalText": "shared.contacts\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nid UUID PK\nname TEXT\nroles TEXT[] DEFAULT '{}'\n  (e.g. ['owner'])\nentity_id UUID \u2192 memory entity graph\ncreated_at, updated_at TIMESTAMPTZ\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nUNIQUE INDEX: owner singleton\n  WHERE 'owner' = ANY(roles)",
