      "id": "finance_tables_text",
      "x": 900,
      "y": 2135,
      "width": 540,
      "height": 550,
      "text": "accounts\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nid UUID PK\ninstitution TEXT\ntype TEXT  (checking/savings/credit/investment)\nname TEXT, last_four CHAR(4)\ncurrency CHAR(3)\nmetadata JSONB\n\ntransactions\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nid UUID PK\naccount_id UUID FK \u2192 accounts\nsource_message_id TEXT\nposted_at TIMESTAMPTZ\nmerchant TEXT, description TEXT\namount NUMERIC(14,2)\ncurrency CHAR(3)\ndirection TEXT  (debit/credit)\ncategory TEXT\npayment_method TEXT\nreceipt_url TEXT, external_ref TEXT\n\nsubscriptions\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nid UUID PK\nservice TEXT\namount NUMERIC(14,2), currency CHAR(3)\nfrequency TEXT  (weekly/monthly/etc)\nnext_renewal DATE\nstatus TEXT  (active/cancelled/paused)\nauto_renew BOOL\n\nbills\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nid UUID PK\npayee TEXT\namount NUMERIC(14,2), currency CHAR(3)\ndue_date DATE, frequency TEXT\nstatus TEXT  (pending/paid/overdue)\nstatement_period_start/end DATE\npaid_at TIMESTAMPTZ",
