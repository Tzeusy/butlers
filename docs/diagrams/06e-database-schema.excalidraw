    {
      "type": "text",
      "id": "memory_module_text",
      "x": 80,
      "y": 2720,
      "width": 620,
      "height": 390,
      "text": "Memory Module\n─────────────────────────\nepisodes\n  id UUID PK, butler TEXT\n  session_id UUID\n  content TEXT\n  embedding vector(384)\n  search_vector tsvector\n  importance FLOAT\n  consolidation_status TEXT\n  expires_at TIMESTAMPTZ\n\nfacts\n  id UUID PK\n  subject TEXT, predicate TEXT\n  content TEXT\n  embedding vector(384)\n  importance FLOAT, confidence FLOAT\n  decay_rate FLOAT\n  permanence TEXT  (stable/standard/volatile)\n  validity TEXT  (active/superseded/retracted)\n  entity_id UUID FK → entities\n  source_episode_id UUID FK → episodes\n\nrules\n  id UUID PK\n  content TEXT, scope TEXT\n  maturity TEXT  (candidate/established/retired)\n  effectiveness_score FLOAT\n  applied_count, success_count, harmful_count\n\nmemory_links\nmemory_events\n\nentities  (memory module)\n  id UUID PK\n  tenant_id TEXT, canonical_name VARCHAR\n  entity_type TEXT  (person/org/place/other)\n  aliases TEXT[]",
      "originalText": "Memory Module\n─────────────────────────\nepisodes\n  id UUID PK, butler TEXT\n  session_id UUID\n  content TEXT\n  embedding vector(384)\n  search_vector tsvector\n  importance FLOAT\n  consolidation_status TEXT\n  expires_at TIMESTAMPTZ\n\nfacts\n  id UUID PK\n  subject TEXT, predicate TEXT\n  content TEXT\n  embedding vector(384)\n  importance FLOAT, confidence FLOAT\n  decay_rate FLOAT\n  permanence TEXT  (stable/standard/volatile)\n  validity TEXT  (active/superseded/retracted)\n  entity_id UUID FK → entities\n  source_episode_id UUID FK → episodes\n\nrules\n  id UUID PK\n  content TEXT, scope TEXT\n  maturity TEXT  (candidate/established/retired)\n  effectiveness_score FLOAT\n  applied_count, success_count, harmful_count\n\nmemory_links\nmemory_events\n\nentities  (memory module)\n  id UUID PK\n  tenant_id TEXT, canonical_name VARCHAR\n  entity_type TEXT  (person/org/place/other)\n  aliases TEXT[]",
      "fontSize": 12,
