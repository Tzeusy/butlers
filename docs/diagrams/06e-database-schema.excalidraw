    {
      "type": "text",
      "id": "messenger_tables_text",
      "x": 80,
      "y": 1735,
      "width": 740,
      "height": 550,
      "text": "delivery_requests\n──────────────\nid UUID PK\nidempotency_key TEXT UNIQUE\nrequest_id UUID\norigin_butler TEXT\nchannel TEXT\nintent TEXT  (send/reply)\ntarget_identity TEXT\nmessage_content TEXT\nstatus TEXT  (pending/in_progress/delivered/\n  failed/dead_lettered)\nterminal_error_class/message TEXT\n\ndelivery_attempts\n──────────────\nid UUID PK\ndelivery_request_id UUID FK → delivery_requests\nattempt_number INTEGER\noutcome TEXT  (success/retryable_error/\n  non_retryable_error/timeout/in_progress)\nerror_class/message TEXT\nlatency_ms INTEGER\n\ndelivery_receipts\n──────────────\nid UUID PK\ndelivery_request_id UUID FK → delivery_requests\nprovider_delivery_id TEXT\nreceipt_type TEXT  (sent/delivered/read/\n  webhook_confirmation)\nreceived_at TIMESTAMPTZ\nmetadata JSONB\n\ndelivery_dead_letter\n──────────────\nid UUID PK\ndelivery_request_id UUID FK → delivery_requests\nquarantine_reason TEXT\ntotal_attempts INTEGER\nreplay_eligible BOOL\ndiscarded_at TIMESTAMPTZ",
