    {
      "type": "text",
      "id": "sw_tables_text",
      "x": 80,
      "y": 680,
      "width": 740,
      "height": 930,
      "text": "butler_registry\n──────────────\nname TEXT PK\nendpoint_url TEXT\ndescription TEXT\nmodules JSONB\nlast_seen_at, registered_at\n\nrouting_log\n──────────────\nid UUID PK\nsource_butler TEXT\ntarget_butler TEXT\ntool_name TEXT\nsuccess BOOL\nduration_ms INTEGER\nerror TEXT, created_at\n\nmessage_inbox  (partitioned by month)\n──────────────\nid UUID, received_at TIMESTAMPTZ PK\nrequest_context JSONB\nraw_payload JSONB\nnormalized_text TEXT\ndecomposition_output JSONB\ndispatch_outcomes JSONB\nresponse_summary TEXT\nlifecycle_state TEXT\nschema_version TEXT\nprocessing_metadata JSONB\ntrace_id TEXT, session_id UUID\n\nconnector_stats_hourly\n──────────────\nconnector_type TEXT\nendpoint_identity TEXT\nhour TIMESTAMPTZ\nmessages_ingested, messages_failed\nsource_api_calls, dedupe_accepted\nheartbeat_count, healthy_count\ndegraded_count, error_count\nPK (connector_type, endpoint_identity, hour)\n\nconnector_stats_daily\n──────────────\n(same as hourly, period=day)\nuptime_pct NUMERIC(5,2)\nPK (connector_type, endpoint_identity, day)\n\nconnector_fanout_daily\n──────────────\nconnector_type, endpoint_identity\ntarget_butler TEXT\nday DATE\nmessage_count BIGINT\n\ndashboard_audit_log\n──────────────\nid UUID PK\nbutler TEXT\noperation TEXT\nrequest_summary JSONB\nresult TEXT\nerror TEXT\nuser_context JSONB\ncreated_at TIMESTAMPTZ\n\n+ 15 more tables: triage_rules, backfill_jobs,\n  routing_instructions, thread_affinity,\n  dead_letter_queue, operator_audit_log,\n  fanout_execution_log, connector_heartbeat,\n  connector_registry w/ capabilities/contracts,\n  notifications, ingress_dedupe, attachments...",
