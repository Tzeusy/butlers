      "text": "shared.ingestion_events  (core_019)\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nid UUID PK  (UUID7 = request_id)\nreceived_at TIMESTAMPTZ\nsource_channel, source_provider TEXT\nsource_endpoint_identity TEXT\nsource_sender_identity TEXT\nsource_thread_identity TEXT\nexternal_event_id, dedupe_key TEXT\ndedupe_strategy, ingestion_tier TEXT\npolicy_tier, triage_decision TEXT\ntriage_target TEXT\n\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\nUNIQUE (dedupe_key)",
