    {
      "type": "text",
      "id": "approvals_module_text",
      "x": 1300,
      "y": 2720,
      "width": 540,
      "height": 230,
      "text": "Approvals Module\n─────────────────────────\napproval_rules\n  id UUID PK\n  tool_name TEXT\n  arg_constraints JSONB\n  description TEXT\n  created_from UUID FK → pending_actions\n  expires_at, max_uses, use_count\n  active BOOL\n\npending_actions\n  id UUID PK\n  tool_name TEXT\n  tool_args JSONB\n  status TEXT  (pending/approved/rejected/\n    expired/executed)\n  approval_rule_id UUID FK → approval_rules\n\napproval_events  (append-only audit)\n  event_id UUID PK\n  action_id UUID FK → pending_actions\n  rule_id UUID FK → approval_rules\n  event_type TEXT  (action_queued/approved/\n    rejected/expired/executed/rule_created/\n    rule_revoked...)\n  actor TEXT",
      "originalText": "Approvals Module\n─────────────────────────\napproval_rules\n  id UUID PK\n  tool_name TEXT\n  arg_constraints JSONB\n  description TEXT\n  created_from UUID FK → pending_actions\n  expires_at, max_uses, use_count\n  active BOOL\n\npending_actions\n  id UUID PK\n  tool_name TEXT\n  tool_args JSONB\n  status TEXT  (pending/approved/rejected/\n    expired/executed)\n  approval_rule_id UUID FK → approval_rules\n\napproval_events  (append-only audit)\n  event_id UUID PK\n  action_id UUID FK → pending_actions\n  rule_id UUID FK → approval_rules\n  event_type TEXT  (action_queued/approved/\n    rejected/expired/executed/rule_created/\n    rule_revoked...)\n  actor TEXT",
