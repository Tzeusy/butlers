    {
      "type": "text",
      "id": "health_tables_text",
      "x": 2240,
      "y": 680,
      "width": 540,
      "height": 750,
      "text": "measurements\n──────────────\nid UUID PK\ntype TEXT\nvalue JSONB  (e.g. {systolic:120})\nmeasured_at TIMESTAMPTZ\nnotes TEXT\n\nmedications\n──────────────\nid UUID PK\nname TEXT, dosage TEXT\nfrequency TEXT\nschedule JSONB\nactive BOOL\n\nmedication_doses\n──────────────\nid UUID PK\nmedication_id UUID FK → medications\ntaken_at TIMESTAMPTZ\nskipped BOOL\n\nconditions\n──────────────\nid UUID PK\nname TEXT\nstatus TEXT  (active/resolved/managed)\ndiagnosed_at TIMESTAMPTZ\n\nsymptoms\n──────────────\nid UUID PK\nname TEXT\nseverity INTEGER 1–10\ncondition_id UUID FK → conditions\noccurred_at TIMESTAMPTZ\n\nmeals\n──────────────\nid UUID PK\ntype TEXT, description TEXT\nnutrition JSONB\neaten_at TIMESTAMPTZ\n\nresearch\n──────────────\nid UUID PK\ntitle TEXT, content TEXT\ntags JSONB, source_url TEXT\ncondition_id UUID FK → conditions\n\n── Memory module (opt-in) ──\nepisodes, facts, rules\nmemory_links, memory_events\nentities  (memory module)\n\n── Contacts module (opt-in) ──\ncontacts_source_accounts\ncontacts_sync_state\ncontacts_source_links",
