    {
      "type": "text",
      "id": "isolation_title",
      "x": 2390,
      "y": 3470,
      "width": 380,
      "height": 22,
      "text": "Schema Isolation Enforcement",
      "originalText": "Schema Isolation Enforcement",
      "fontSize": 14,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#991b1b",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 1600003,
      "version": 1,
      "versionNonce": 1600004,
      "isDeleted": false,
      "groupIds": [],
