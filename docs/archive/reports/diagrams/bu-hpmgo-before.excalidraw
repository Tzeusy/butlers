    {
      "type": "text",
      "id": "legend-before",
      "x": 60,
      "y": 370,
      "width": 600,
      "height": 60,
      "text": "Problems: (1) No reconciled_transaction_id column — bills.paid link was LLM prose only\n(2) track_bill_fact was a live tool that diverged from the table upsert\n(3) Session death = settlement forgotten; HSBC $717.57 stuck pending indefinitely",
      "originalText": "Problems: (1) No reconciled_transaction_id column — bills.paid link was LLM prose only\n(2) track_bill_fact was a live tool that diverged from the table upsert\n(3) Session death = settlement forgotten; HSBC $717.57 stuck pending indefinitely",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#D16969",
      "backgroundColor": "transparent",
